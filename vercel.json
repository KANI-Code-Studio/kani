{
  "rewrites": [
    {
      "source": "/course/iot-cohort-1",
      "destination": "https://iot-cohort-1.vercel.app/"
    },
    {
      "source": "/course/iot-cohort-1/:match*",
      "destination": "https://iot-cohort-1.vercel.app/:match*"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "/robots.txt"
    },
  ]
}
